		{
			"name": "Webhook (Meta WhatsApp Cloud API)",
			"item": [
				{
					"name": "Verificación del Webhook (GET)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/webhook?hub.mode=subscribe&hub.verify_token={{verify_token}}&hub.challenge=CHALLENGE_ACCEPTED",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"webhook"
							],
							"query": [
								{
									"key": "hub.mode",
									"value": "subscribe"
								},
								{
									"key": "hub.verify_token",
									"value": "{{verify_token}}"
								},
								{
									"key": "hub.challenge",
									"value": "CHALLENGE_ACCEPTED"
								}
							]
						},
						"description": "Simula la petición GET que realiza Meta para verificar la validez de tu servidor webhook. Utiliza la variable `verify_token` configurada en el entorno."
					},
					"response": []
				},
				{
