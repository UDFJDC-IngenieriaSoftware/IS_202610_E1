		{
			"name": "Webhook (Meta WhatsApp Cloud API)",
			"item": [
				{
					"name": "Verificación del Webhook (GET)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/webhook/whatsapp?hub.mode=subscribe&hub.verify_token={{verify_token}}&hub.challenge=CHALLENGE_ACCEPTED",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"webhook",
								"whatsapp"
							],
							"query": [
								{
									"key": "hub.mode",
									"value": "subscribe"
								},
								{
									"key": "hub.verify_token",
									"value": "{{verify_token}}"
								},
								{
									"key": "hub.challenge",
									"value": "CHALLENGE_ACCEPTED"
								}
							]
						},
						"description": "Simula la petición GET de Meta para verificar el webhook. Usa la variable `verify_token`.\n\nEn local con backend directo también responde en `{{base_url}}/webhook`."
