    "qrcode-terminal": "^0.12.0",
    "redis": "^4.7.0",
    "sequelize": "^6.37.3",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "sequelize-cli": "^6.6.5",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
