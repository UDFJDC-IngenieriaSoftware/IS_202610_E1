NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=5433
POSTGRES_DB=bot_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
DB_SYNC=false

JWT_SECRET=change-this-secret-in-every-environment-minimum-32-chars
